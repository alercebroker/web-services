<meta name="htmx-config" content='{"selfRequestsOnly": false}'>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="stylesheet" href="{{API_URL}}/static/loading_indicators.css">

<div id="sn_hunter_objects_table" class="tw-preflight tw-text-black tw-bg-white dark:tw-bg-[#1e1e1e] dark:tw-text-white">

    <div class="loader">
        <div id="table-objects-loading" class="loaderBar astronomical-loading-indicator"></div>
    </div>
    {{ objects_list }}
    <table 
    id="sn_hunter_main_table"
    class="tw-table-auto tw-border-collapse tw-bg-white tw-text-left tw-w-full dark:tw-bg-[#1e1e1e]"
    data-sn="{{ objects_list }}"
    >
        <thead class="tw-text-[0.875rem] tw-text-black/60 dark:tw-text-white/70 sm:tw-table-header-group">
            <tr class="tw-h-[34px]">
            </tr>
        </thead>

        <tbody class="tw-text-[0.875rem] tw-text-black dark:tw-text-white">
        </tbody>
    </table>

</div>


<script type="module">


function init() {
    let raw = document.getElementById('sn_hunter_main_table');
    let data = JSON.parse(raw.dataset.sn);
    console.log(data);
}


init();
</script>
