<meta name="htmx-config" content='{"selfRequestsOnly": false}'>
<link rel="stylesheet" href="{{API_URL}}/static/object.css">
<script src="{{API_URL}}/htmx/htmx.min.js"></script>

<div id="sidebar-container" class="tw-preflight tw-w-full tw-text-black tw-bg-transparent dark:tw-bg-[#424242] dark:tw-text-[#EEEEEE]">
    
    <!-- Loader: Div propio en el flujo (empuja el contenido sutilmente) -->
    <div id="sidebar-loader" class="htmx-indicator tw-w-full tw-border-b tw-border-[#616161]/30">
        <div class="tw-flex tw-items-center tw-justify-center tw-py-4 tw-gap-3">
            <div class="alerce-spinner" style="width: 20px; height: 20px; border-width: 2px;"></div>
            <span class="fetching-text" style="font-size: 13px;">Loading oids...</span>
        </div>
    </div>

    <!-- Contenido -->
    <div id="sidebar-content">
        {% if objects_list['items']|length > 0 %}
            <input id="objects-store" class="tw-hidden" data-objects="{{ objects_list['items'] }}">
            <input id="selected_oid_cache" class="tw-hidden" value="{{selected_oid}}">

            <div id="sidebar-objects-htmx" class="tw-flex tw-flex-col tw-w-full tw-h-[95vh] tw-text-[0.875rem]">
                
                <div class="tw-px-4 tw-text-black/60 dark:tw-text-white/70 tw-border-y tw-border-[#616161] tw-h-[45px] tw-flex tw-items-center tw-justify-start">
                    Object List
                </div>

                {% for item in objects_list['items']%}
                    {% if item['oid']|string != selected_oid|string %}
                        <div
                        data-oid='{{item["oid"]}}'
                        name="sidebar-row-element" 
                        class="tw-flex tw-items-center tw-justify-start tw-h-[45px] hover:tw-bg-[#b2b2b2]/50 hover:tw-cursor-pointer"
                        hx-get="{{API_URL}}/htmx/side_objects"
                        hx-trigger="click"
                        hx-swap="outerHTML"
                        hx-target="#sidebar-container"
                        hx-indicator="#sidebar-loader"
                        hx-on::config-request="prepare_params(event)"
                        >
                            <span class="tw-px-4 tw-inline-block">{{item['oid']}}</span>
                        </div>
                    {% else %}
                        <div name="sidebar-row-element" class="tw-flex tw-items-center tw-justify-start tw-h-[45px] tw-text-[#1976D2] tw-font-medium tw-bg-[#1976D2]/30">
                            <span class="tw-px-4 tw-inline-block">{{selected_oid}}</span>
                        </div>
                    {% endif %}
                {% endfor %}
            </div>

            <!-- Paginación -->
            <div class="tw-flex tw-justify-center tw-items-center tw-text-base tw-h-[48px] tw-text-black dark:tw-text-[#EEEEEE]">
                {% if has_prev %}
                    <span 
                    id="prev_page"
                    name="side_objects_btn"
                    data-next="{{prev}}"
                    hx-get="{{API_URL}}/htmx/side_objects"
                    hx-trigger="click"
                    hx-swap="outerHTML"
                    hx-target="#sidebar-container"
                    hx-indicator="#sidebar-loader"
                    hx-on::config-request="prepare_params(event)"
                    class="tw-inline-block hover:tw-bg-[#b2b2b2] hover:tw-cursor-pointer"
                    >
                        <svg class="tw-h-[24px] tw-w-[24px] tw-fill-current" viewBox="0 -960 960 960">
                            <path d="M400-240 160-480l240-240 56 58-142 142h486v80H314l142 142-56 58Z"/>
                        </svg>
                    </span>
                {% endif %}
                
                <span id="current_page" data-page="{{objects_list['current_page']}}" class="tw-inline-block tw-text-sm tw-text-center tw-h-[28px] tw-w-[48px] tw-flex tw-items-center tw-justify-center">
                    {{objects_list['current_page']}}
                </span>
                
                {% if has_next %}
                    <span 
                    id="next_page"
                    name="side_objects_btn"
                    data-next="{{next}}"
                    hx-get="{{API_URL}}/htmx/side_objects"
                    hx-trigger="click"
                    hx-swap="outerHTML"
                    hx-target="#sidebar-container"
                    hx-indicator="#sidebar-loader"
                    hx-on::config-request="prepare_params(event)"
                    class="tw-inline-block hover:tw-bg-[#b2b2b2] hover:tw-cursor-pointer"
                    >
                        <svg class="tw-h-[24px] tw-w-[24px] tw-fill-current" viewBox="0 -960 960 960">
                            <path d="m560-240-56-58 142-142H160v-80h486L504-662l56-58 240 240-240 240Z"/>
                        </svg>
                    </span>
                {% endif %}
            </div>
        {% else %}
            <div id="sidebar-objects-htmx" class="tw-flex tw-items-center tw-justify-center tw-h-[100px] tw-text-black/50 dark:tw-text-white/50">
                No results found
            </div>
        {% endif %}
    </div>
</div>

<script type="module">
    import {init, elementReady} from "{{API_URL}}/static/sidebar.js"
    elementReady("#sidebar-objects-htmx").then(() => {
        init();
    });
</script>
