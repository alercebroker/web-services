<!-- Periodogram container – initialised by lightcurve-app.js when fold is enabled -->
<div id="periodogram" style="width: 100%; height: 100%; min-height: 130px;"></div>
<!-- Shown while the periodogram is being computed on first fold enable -->
<div id="periodogram-loading" class="tw-hidden tw-h-full tw-flex tw-items-center tw-justify-center">
  <span class="tw-text-gray-500 dark:tw-text-gray-400 tw-animate-pulse">Computing periodogram…</span>
</div>
<!-- Shown when fold is on but no period was found -->
<div id="no-period-message" class="tw-hidden tw-h-full tw-flex tw-items-center tw-justify-center">
  <div class="tw-bg-yellow-50 dark:tw-bg-yellow-900 tw-border tw-border-yellow-200 dark:tw-border-yellow-700 tw-rounded-md tw-p-4 tw-mb-4">
    <strong class="tw-text-yellow-800 dark:tw-text-yellow-200">Info:</strong>
    <span class="tw-text-yellow-700 dark:tw-text-yellow-300">No period computed for this object. Periodogram not available.</span>
  </div>
</div>
