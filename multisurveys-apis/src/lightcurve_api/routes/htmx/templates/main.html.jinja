<div class="tw-relative tw-grid tw-grid-cols-12 tw-h-full tw-bg-white dark:tw-bg-[#1e1e1e]">

  <!-- External sources picker overlay – populated by HTMX on demand -->
  <div id="dr-picker-container" class="tw-hidden tw-absolute tw-inset-0 tw-z-50 tw-bg-white dark:tw-bg-[#1e1e1e] tw-overflow-auto tw-p-4">
  </div>

  <div class="tw-col-span-full tw-order-first tw-h-full md:tw-col-span-9 md:tw-order-none">

    <!-- Warning shown by JS when corrected magnitudes are unavailable in Total mode -->
    <div id="not-corrected-warning" class="tw-hidden tw-h-full tw-flex tw-items-center tw-justify-center">
      <div class="tw-bg-yellow-50 dark:tw-bg-yellow-900 tw-border tw-border-yellow-200 dark:tw-border-yellow-700 tw-rounded-md tw-p-4 tw-mb-4">
        <strong class="tw-text-yellow-800 dark:tw-text-yellow-200">Info:</strong>
        <span class="tw-text-yellow-700 dark:tw-text-yellow-300">Lightcurve not corrected. Lightcurve plot not available for Total magnitude. Switch back to Difference.</span>
      </div>
    </div>

    <div id="plot-grid" class="tw-mx-4 tw-flex tw-flex-col tw-gap-4 tw-h-80 md:tw-h-full">
      <div id="lightcurve-container" class="tw-flex-1 tw-min-h-0 tw-w-full">
        {% include "lightcurve.html.jinja" %}
      </div>

      <!-- Periodogram container – hidden until fold + periodogram_enabled are on -->
      <div id="periodogram-container" class="tw-hidden tw-flex-1 tw-min-h-0 tw-max-h-[200px] tw-w-full">
        {% include "periodogram.html.jinja" %}
      </div>
    </div>

  </div>

  <div class="tw-col-span-full tw-order-last tw-py-4 tw-text-center tw-mx-3 md:tw-col-span-3 md:tw-order-none">
    {% include "config_panel.html.jinja" %}
  </div>

</div>

